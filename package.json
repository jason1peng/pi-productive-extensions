{
  "name": "pi-productive-extensions",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "subagents": {
      "agents": [
        "./extensions/delivery-state-machine/agents/dsm"
      ]
    }
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "scripts": {
    "test": "bash scripts/test-with-host-modules.sh",
    "eval:models:validate": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts validate",
    "eval:models:fake-full": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts fake-full",
    "eval:models:audit": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts audit",
    "eval:models:audit-real": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts audit-real",
    "eval:models:bootstrap:canary": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts bootstrap-canary",
    "eval:models:bootstrap:e2e": "bun extensions/delivery-state-machine/benchmarks/model-quality/run.ts bootstrap-e2e",
    "eval:dsm-agents:validate": "bun extensions/delivery-state-machine/benchmarks/agent-quality/run.ts validate && promptfoo validate -c extensions/delivery-state-machine/benchmarks/agent-quality/promptfooconfig.yaml",
    "eval:dsm-agents:canary": "bun extensions/delivery-state-machine/benchmarks/agent-quality/canary.ts",
    "eval:dsm-agents": "promptfoo eval -c extensions/delivery-state-machine/benchmarks/agent-quality/promptfooconfig.yaml --no-cache",
    "eval:dsm-agents:smoke": "npm run eval:dsm-agents -- --filter-pattern '^VER-01 dsm[.]verifier$' --repeat 1",
    "eval:dsm-agents:implement": "npm run eval:dsm-agents -- --filter-pattern '^IMP-' --repeat 1",
    "eval:dsm-agents:verify": "npm run eval:dsm-agents -- --filter-pattern '^VER-' --repeat 1",
    "eval:dsm-agents:review": "npm run eval:dsm-agents -- --filter-pattern '^REV-' --repeat 1",
    "eval:dsm-agents:close": "npm run eval:dsm-agents -- --filter-pattern '^CLO-' --repeat 1",
    "eval:dsm-agents:retro": "npm run eval:dsm-agents -- --filter-pattern '^RET-' --repeat 1",
    "eval:dsm-agents:full": "npm run eval:dsm-agents -- --repeat 3",
    "report-viewer": "bun apps/report-viewer/src/server.ts",
    "report-viewer:migrate": "bun apps/report-viewer/scripts/migrate-delivery-reports.ts",
    "report-viewer:tailscale": "bash apps/report-viewer/scripts/tailscale.sh",
    "report-viewer:verify": "bun apps/report-viewer/tests/report-viewer.test.ts",
    "verify": "npm run test && npm run report-viewer:verify"
  },
  "dependencies": {
    "promptfoo": "0.121.19"
  }
}
